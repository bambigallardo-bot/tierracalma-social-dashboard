# ===== Meta (Instagram orgánico + Meta Ads) — Tierra Calma =====
# Token de larga duración o de System User con permisos:
#   read_insights, pages_show_list, instagram_basic, instagram_manage_insights, ads_read, business_management
META_ACCESS_TOKEN=

# IDs de Tierra Calma:
META_AD_ACCOUNT_ID=523272021711752   # "Cuenta Publicitarias MÁS CENTER / TIERRA CALMA" (compartida; con o sin act_)
META_IG_USER_ID=                     # Instagram Business de Tierra Calma (pendiente: resolver desde @usuario)

# La cuenta es compartida "MÁS CENTER / TIERRA CALMA". Aquí mostramos SOLO Tierra Calma:
# se incluyen únicamente las campañas cuyo nombre contenga estos substrings (en minúsculas, coma).
# META_INCLUDE_CAMPAIGNS=tierra calma

# Opcionales
# META_GRAPH_VERSION=v21.0
# SOCIAL_MONTHS=12                    # meses de historial a traer
# DASHBOARD_CACHE_MS=600000           # caché en memoria (10 min)

# ===== Modo edición (versión interna con clave) =====
# Clave para entrar a /?edit y editar conclusiones + aprendizajes de Meta.
EDIT_PASSWORD=
# Almacenamiento para que lo editado lo vea el cliente (Vercel Blob, GRATIS en Hobby).
# Conectar un Blob store al proyecto inyecta el token solo (no hace falta pegarlo).
# BLOB_READ_WRITE_TOKEN=

# ===== Protección opcional del link (HTTP Basic). Vacías = link ABIERTO =====
# DASHBOARD_USER=tierracalma
# DASHBOARD_PASSWORD=una_clave_segura
